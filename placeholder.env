# =============================================================================
# GOOGLE AUTH - Configuración del Proyecto
# =============================================================================
# Este archivo sirve como plantilla para las variables de entorno requeridas.
# Copia este contenido a un archivo llamado .env y reemplaza los valores.
#
# ⚠️ IMPORTANTE: Nunca subas el archivo .env con credenciales reales al repositorio.
# =============================================================================

# =============================================================================
# SECCIÓN 1: CONFIGURACIÓN DEL SERVIDOR
# =============================================================================
# Puerto donde correra el servidor Express
# Default: 9287
PORT=9287

# Entorno de ejecución
# Opciones: development, production, test
# Default: development
NODE_ENV=development


# =============================================================================
# SECCIÓN 2: GOOGLE OAUTH CONFIGURATION
# =============================================================================
# Para obtener las credenciales de Google OAuth:
# 1. Ve a https://console.cloud.google.com/
# 2. Crea un nuevo proyecto o selecciona uno existente
# 3. Ve a "APIs y servicios" > "Credenciales"
# 4. Crea credenciales OAuth 2.0 Client ID
# 5. Configura la URI de redirección autorizada
#
# URI de redirección autorizada debe incluir:
# http://localhost:9287/auth/google/callback

# Client ID de tu aplicación Google Cloud
# Formato típico: xxxxxxxx-xxxxxxxx.apps.googleusercontent.com
GOOGLE_ID_SECRET=your_google_client_id.apps.googleusercontent.com

# Client Secret de tu aplicación Google Cloud
# Este valor se muestra solo al crear las credenciales
GOOGLE_SECRET_CLIENT_PASSWORD=your_google_client_secret

# URL de redirección después de autenticarse con Google
# IMPORTANTE: Debe coincidir con la URI autorizada en Google Cloud Console
# Desarrollo: http://localhost:9287/auth/google/callback
# Producción:  https://tu-dominio.com/auth/google/callback
REDIRECT_URL=http://localhost:9287/auth/google/callback


# =============================================================================
# SECCIÓN 3: SEGURIDAD DE SESIÓN
# =============================================================================
# Secreto para firmar y verificar las sesiones de usuario.
# IMPORTANTE: Usa una cadena larga y aleatoria (mínimo 32 caracteres).
# En producción, genera uno nuevo y guárdalo de forma segura.
# Generador sugerido: https://randomkeygen.com/ (usa una clave de 64+ caracteres)
TOKEN_AUTHORIZED_SESSION=your_secure_session_token_min_32_chars_long


# =============================================================================
# SECCIÓN 4: CONFIGURACIÓN DE EMAIL (SMTP)
# =============================================================================
# Configuración del servidor SMTP para enviar emails (verificación, reset, etc.)
# Si usas Gmail, consulta la sección de abajo para obtener App Password.

# Servidor SMTP (host)
# Ejemplos:
#   - Gmail:    smtp.gmail.com
#   - Outlook:  smtp.office365.com
#   - Yahoo:    smtp.mail.yahoo.com
EMAIL_HOST=smtp.gmail.com

# Puerto SMTP
# Puertos comunes:
#   - 587  = TLS (recomendado)
#   - 465  = SSL
#   - 25   = SMTP sin cifrar (no recomendado)
EMAIL_PORT=587

# Usar conexión segura (SSL/TLS)
# true  = Usa SSL en el puerto 465
# false = Usa TLS en el puerto 587
EMAIL_SECURE=false

# Usuario del email (generalmente tu email completo)
EMAIL_USER=your_email@gmail.com

# Contraseña del email o App Password (ver abajo)
EMAIL_PASS=your_app_password


# =============================================================================
# CÓMO OBTENER APP PASSWORD DE GMAIL (Si usas Gmail)
# =============================================================================
# IMPORTANTE: Tu contraseña regular de Gmail NO funcionará.
# Debes generar una "App Password" específica para la aplicación.
#
# Pasos para generar App Password:
# 1. Inicia sesión en tu cuenta Google
# 2. Ve a https://myaccount.google.com/
# 3. Seguridad > Verificación en 2 pasos (debe estar activada)
# 4. Busca "Contraseñas de aplicaciones" en la barra de búsqueda
# 5. Crea una nueva contraseña de aplicación
# 6. Selecciona "Otro" y dale un nombre (ej: "Google Auth Server")
# 7. Copia la contraseña de 16 caracteres generada
#
# NOTA: Si no ves la opción de App Password, tu cuenta puede tener
# verificación en 2 pasos deshabilitada o necesitas habilitarla.


# =============================================================================
# RESUMEN DE VARIABLES REQUERIDAS
# =============================================================================
# REQUERIDAS:
#   - GOOGLE_ID_SECRET
#   - GOOGLE_SECRET_CLIENT_PASSWORD
#   - REDIRECT_URL
#   - TOKEN_AUTHORIZED_SESSION
#   - EMAIL_HOST
#   - EMAIL_PORT
#   - EMAIL_USER
#   - EMAIL_PASS
#
# OPCIONALES (tienen valores por defecto):
#   - PORT (default: 9287)
#   - NODE_ENV (default: development)
#   - EMAIL_SECURE (default: false)
